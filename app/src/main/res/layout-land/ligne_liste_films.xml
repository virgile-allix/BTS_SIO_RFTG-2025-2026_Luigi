<?xml version="1.0" encoding="utf-8"?>
<!-- Layout ligne film optimisé pour paysage - plus compact en hauteur -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="#FFFFFF"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Image plus petite en paysage -->
        <ImageView
            android:id="@+id/ivFilmPoster"
            android:layout_width="50dp"
            android:layout_height="75dp"
            android:background="#E8E8E8"
            android:scaleType="centerCrop"
            android:contentDescription="Affiche du film"
            android:layout_marginEnd="12dp"/>

        <!-- Informations du film -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_gravity="center_vertical">

            <TextView
                android:id="@+id/textNomFilm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ACADEMY DINOSAUR"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="4dp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/textSupport"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sur place"
                    android:textSize="10sp"
                    android:textColor="#666666"
                    android:background="#F5F5F5"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/textDescription"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="description"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:maxLines="1"
                    android:ellipsize="end"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Boutons côte à côte en paysage -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginStart="8dp"
            android:layout_gravity="center_vertical">

            <Button
                android:id="@+id/btnDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Détail"
                android:textSize="12sp"
                android:backgroundTint="@android:color/white"
                android:textColor="#3B82F6"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnAjouter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ajouter"
                android:textSize="12sp"
                android:backgroundTint="#3B82F6"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:minWidth="0dp"
                android:minHeight="0dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
