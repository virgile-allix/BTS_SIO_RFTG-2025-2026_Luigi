<?xml version="1.0" encoding="utf-8"?>
<!-- Layout optimisé pour orientation paysage (landscape) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- En-tête plus compact en paysage -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="24sp"
            android:textColor="#000000"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:onClick="onRetourClicked"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Catalogue"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginEnd="12dp"/>

        <!-- Barre de recherche inline en paysage -->
        <EditText
            android:id="@+id/etRecherche"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="40dp"
            android:hint="Rechercher..."
            android:paddingStart="36dp"
            android:paddingEnd="12dp"
            android:background="@android:drawable/edit_text"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="8dp"
            android:textSize="14sp"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/btnPanier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Panier"
            android:textSize="16sp"
            android:textColor="#3B82F6"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:onClick="onPanierClicked"/>

    </LinearLayout>

    <!-- Liste des films -->
    <ListView
        android:id="@+id/listeFilms"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"/>

</LinearLayout>
