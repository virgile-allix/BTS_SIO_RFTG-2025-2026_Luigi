<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- En-tête avec titre et bouton retour -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/btnRetourPanier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="24sp"
            android:textColor="#000000"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:onClick="onRetourClicked"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/tvPanier"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Panier"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"/>

    </LinearLayout>

    <!-- Liste des films dans le panier -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPanierItems"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false"/>

    <!-- Message si panier vide -->
    <TextView
        android:id="@+id/tvPanierVide"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Votre panier est vide"
        android:textSize="16sp"
        android:textColor="#666666"
        android:gravity="center"
        android:visibility="gone"/>

    <!-- Boutons d'action -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <Button
            android:id="@+id/btnViderPanier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vider le panier"
            android:backgroundTint="@android:color/white"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="14dp"
            android:onClick="onViderPanierClicked"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnValiderReservation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Valider la réservation"
            android:backgroundTint="#3B82F6"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="14dp"
            android:onClick="onValiderReservationClicked"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvContinuerAchats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Continuer les achats"
            android:textAlignment="center"
            android:textSize="16sp"
            android:textColor="#3B82F6"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:onClick="onContinuerAchatsClicked"/>

    </LinearLayout>

</LinearLayout>
