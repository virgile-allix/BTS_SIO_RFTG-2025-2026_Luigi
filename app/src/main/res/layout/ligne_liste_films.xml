<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/list_item_spacing"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="#FFFFFF"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/padding_standard">

        <!-- Image placeholder pour l'affiche -->
        <ImageView
            android:id="@+id/ivFilmPoster"
            android:layout_width="@dimen/poster_width_list"
            android:layout_height="@dimen/poster_height_list"
            android:background="#E8E8E8"
            android:scaleType="centerCrop"
            android:contentDescription="Affiche du film"
            android:layout_marginEnd="@dimen/margin_standard"/>

        <!-- Informations du film -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textNomFilm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ACADEMY DINOSAUR"
                android:textSize="@dimen/text_size_medium"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="@dimen/margin_small"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/textSupport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sur place"
                android:textSize="@dimen/text_size_tiny"
                android:textColor="#666666"
                android:background="#F5F5F5"
                android:paddingStart="@dimen/padding_small"
                android:paddingEnd="@dimen/padding_small"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginBottom="@dimen/margin_small"/>

            <TextView
                android:id="@+id/textDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="description de camille dial"
                android:textSize="@dimen/text_size_small"
                android:textColor="#666666"
                android:lineSpacingExtra="2dp"
                android:maxLines="2"
                android:ellipsize="end"/>

        </LinearLayout>

        <!-- Boutons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="8dp">

            <Button
                android:id="@+id/btnDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Détail"
                android:textSize="@dimen/text_size_small"
                android:backgroundTint="@android:color/white"
                android:textColor="#3B82F6"
                android:textStyle="bold"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:focusable="false"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnAjouter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ajouter"
                android:textSize="@dimen/text_size_small"
                android:backgroundTint="#3B82F6"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:focusable="false"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
