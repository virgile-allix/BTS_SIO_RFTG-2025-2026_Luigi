<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@android:color/white">

    <!-- Bouton croix rouge pour fermer l'appli -->
    <Button
        android:id="@+id/btnFermerAppli"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:text="✕"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:backgroundTint="#E53935"
        android:padding="0dp"
        android:onClick="onFermerAppliClicked"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Luigi Films"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvEmailLabel"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvEmailLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Email"
        android:textSize="14sp"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/etIdentifiant"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etIdentifiant"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        app:layout_constraintTop_toBottomOf="@id/tvEmailLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvPasswordLabel"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvPasswordLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Mot de passe"
        android:textSize="14sp"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toBottomOf="@id/etIdentifiant"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/etMdp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etMdp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="••••••"
        android:inputType="textPassword"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        app:layout_constraintTop_toBottomOf="@id/tvPasswordLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvUrlLabel"
        android:layout_marginBottom="20dp"/>

    <!-- Sélecteur d'URL du serveur -->
    <TextView
        android:id="@+id/tvUrlLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="URL du serveur"
        android:textSize="14sp"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toBottomOf="@id/etMdp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/spinnerUrl"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinnerUrl"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@android:drawable/edit_text"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvUrlLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvUrlPersonnaliseeLabel"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvUrlPersonnaliseeLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Ou saisir une URL personnalisée :"
        android:textSize="12sp"
        android:textColor="#666666"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/spinnerUrl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/etUrlPersonnalisee"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etUrlPersonnalisee"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="http://..."
        android:inputType="textUri"
        android:padding="10dp"
        android:textSize="13sp"
        android:background="@android:drawable/edit_text"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvUrlPersonnaliseeLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnConnexion"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnConnexion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Se connecter"
        android:textColor="@android:color/white"
        android:backgroundTint="#3B82F6"
        android:padding="16dp"
        android:textSize="16sp"
        android:onClick="onConnexionClicked"
        app:layout_constraintTop_toBottomOf="@id/etUrlPersonnalisee"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvMotDePasseOublie"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvMotDePasseOublie"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mot de passe oublié ?"
        android:textSize="14sp"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toBottomOf="@id/btnConnexion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnCreerCompte"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnCreerCompte"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Créer un compte"
        android:textColor="@android:color/black"
        android:backgroundTint="@android:color/white"
        android:padding="16dp"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tvMotDePasseOublie"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
